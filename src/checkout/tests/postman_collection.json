{
  "info": {
    "name": "Checkout API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": { "method": "GET", "url": "{{base_url}}/health" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', () => pm.response.to.have.status(200));",
        "pm.test('Status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
      ]}}]
    },
    {
      "name": "Topology",
      "request": { "method": "GET", "url": "{{base_url}}/topology" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', () => pm.response.to.have.status(200));",
        "pm.test('Has persistenceProvider', () => pm.expect(pm.response.json()).to.have.property('persistenceProvider'));"
      ]}}]
    },
    {
      "name": "Update Checkout",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/checkout/customer-123/update",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"items\":[{\"id\":\"item-1\",\"name\":\"Widget\",\"quantity\":1,\"price\":2000}],\"shippingAddress\":{\"firstName\":\"Test\",\"lastName\":\"User\",\"address1\":\"123 St\",\"city\":\"NYC\",\"state\":\"NY\",\"zip\":\"10001\",\"email\":\"test@test.com\"}}"
        }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
        "pm.test('Has items', () => pm.expect(pm.response.json()).to.have.property('items'));",
        "pm.test('Has subtotal', () => pm.expect(pm.response.json().subtotal).to.eql(2000));"
      ]}}]
    },
    {
      "name": "Get Checkout",
      "request": { "method": "GET", "url": "{{base_url}}/checkout/customer-123" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', () => pm.response.to.have.status(200));",
        "pm.test('Has items', () => pm.expect(pm.response.json()).to.have.property('items'));"
      ]}}]
    }
  ]
}